{
  "name": "@border-empires/server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:ai-replay": "pnpm build && AI_REPLAY_USE_DIST=1 node --import tsx src/ai/run-planning-static-replay-smoke.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "simulate:load": "tsx src/simulate.ts"
  },
  "dependencies": {
    "@border-empires/shared": "workspace:*",
    "@fastify/cors": "^8.5.0",
    "@fastify/websocket": "^10.0.1",
    "fastify": "^4.29.1",
    "firebase-admin": "^13.7.0",
    "jose": "^6.2.2",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
