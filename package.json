{
  "name": "border-empires",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @border-empires/shared build && pnpm --parallel --filter @border-empires/server --filter @border-empires/client dev",
    "dev:clean": "./scripts/clean-dev.sh",
    "dev:nofog": "DISABLE_FOG=1 pnpm dev",
    "ci:local": "./scripts/local-ci.sh",
    "server:restart": "./scripts/restart-server.sh",
    "deploy:client:prod": "node ./scripts/deploy-client-prod.mjs",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  }
}
