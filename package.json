{
  "name": "border-empires",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @border-empires/shared build && pnpm --parallel --filter @border-empires/simulation --filter @border-empires/realtime-gateway --filter @border-empires/client dev",
    "dev:legacy": "pnpm --filter @border-empires/shared build && pnpm --parallel --filter @border-empires/server --filter @border-empires/client dev",
    "dev:clean": "./scripts/clean-dev.sh",
    "dev:nofog": "DISABLE_FOG=1 pnpm dev:legacy",
    "rewrite:restart": "./scripts/restart-rewrite-stack.sh",
    "rewrite:restart:20ai": "./scripts/restart-rewrite-stack-20ai.sh",
    "rewrite:restart:20ai:seed": "./scripts/restart-rewrite-stack-20ai-seed.sh",
    "rewrite:db:migrate": "node ./scripts/rewrite-db-migrate.mjs",
    "rewrite:db:size": "node ./scripts/rewrite-db-size.mjs",
    "deploy:rewrite:gateway": "fly deploy --config fly.gateway.toml",
    "deploy:rewrite:simulation": "fly deploy --config fly.simulation.toml",
    "ops:staging:login-probe": "node ./scripts/staging-login-latency-probe.mjs --attempts 12 --timeout-ms 8000 --max-p95-ms 5000 --min-success-rate 1",
    "check:client-changelog": "node ./scripts/check-client-changelog-update.mjs",
    "ci:local": "./scripts/local-ci.sh",
    "server:restart": "./scripts/restart-server.sh",
    "deploy:client:preview": "node ./scripts/deploy-client-preview.mjs",
    "deploy:client:staging": "node ./scripts/deploy-client-preview.mjs",
    "deploy:client:prod": "node ./scripts/deploy-client-prod.mjs",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  }
}
