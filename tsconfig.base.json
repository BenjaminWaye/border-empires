{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useDefineForClassFields": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@border-empires/shared": ["packages/shared/dist/index"],
      "@border-empires/client-protocol": ["packages/client-protocol/dist/index"],
      "@border-empires/game-domain": ["packages/game-domain/dist/index"],
      "@border-empires/sim-protocol": ["packages/sim-protocol/dist/index"]
    }
  }
}
