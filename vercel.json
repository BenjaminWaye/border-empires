{
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @border-empires/shared --filter @border-empires/client-protocol --filter @border-empires/sim-protocol --filter @border-empires/game-domain build && pnpm --filter @border-empires/client build",
  "outputDirectory": "packages/client/dist",
  "rewrites": [
    { "source": "/rally/new", "destination": "/" },
    { "source": "/r/:code", "destination": "/" }
  ]
}
